# ===================================================
# A-Ka Backend 환경변수 템플릿
# 이 파일을 .env로 복사한 뒤 실제 값을 입력하세요
# cp .env.example .env
# ===================================================

# ── 데이터베이스 (PostgreSQL) ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=여기에_PostgreSQL_비밀번호
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=aka_db
DATABASE_URL=postgresql://postgres:비밀번호@127.0.0.1:5432/aka_db

# ── Redis (Celery 브로커) ──
# Windows에서는 localhost 대신 127.0.0.1을 사용해야 합니다 (IPv6 이슈 방지)
REDIS_URL=redis://127.0.0.1:6379/0

# ── 외부 API 키 ──
OPENAI_API_KEY=sk-proj-여기에_OpenAI_API_키_입력
YOUTUBE_API_KEY=여기에_YouTube_API_키_입력
NOTION_API_KEY=ntn_여기에_Notion_API_키_입력

JWT_SECRET_KEY=SECRET_KEY 입력
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30